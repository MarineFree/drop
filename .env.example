# ─────────────────────────────────────────────────────────────────────────────
# Drop — variables d'environnement
#
# Local dev : copier ce fichier en .env.local, remplir les clés, lancer pnpm dev.
# Production Hostinger (Dokploy) : coller ces vars dans la GUI du service app.
# Les vars marquées `# DIFFER` ont des valeurs différentes local vs prod.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Base de données ────────────────────────────────────────────────────────
# Local : Docker Postgres OU Supabase pooler.
# Prod Hostinger : service PostgreSQL Dokploy → utiliser le hostname interne
#   du conteneur (ex: drop-db.<network>). Schema par défaut = public.
# DIFFER
DATABASE_URL="postgresql://user:pass@localhost:5432/drop?schema=public"

# ─── Anthropic (Claude) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# Modèle primaire pour DropContent.
#   sonnet (défaut) → claude-sonnet-4-6 — moins cher, latence + faible, qualité
#                     suffisante pour du JSON contraint par Zod + system prompt.
#   opus            → claude-opus-4-7  — opt-in pour cas exigeants.
# Le fallback est automatique vers Sonnet en cas de fail API.
DROP_GENERATION_MODEL="sonnet"

# ─── fal.ai — Flux Schnell (image hero) ─────────────────────────────────────
FAL_KEY=""

# ─── OpenAI — Whisper (transcription vocale uniquement) ─────────────────────
OPENAI_API_KEY=""

# ─── Resend — email transactionnel (magic link Better Auth) ─────────────────
# Clé API : https://resend.com/api-keys
# RESEND_FROM_EMAIL :
#   - onboarding@resend.dev → sandbox (livre uniquement à l'email du compte Resend)
#   - auth@<your-verified-domain> → prod (domaine vérifié dans Resend)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"

# ─── Better Auth ────────────────────────────────────────────────────────────
# BETTER_AUTH_SECRET = clé HMAC pour signer les sessions. 32+ bytes aléatoires.
#   Générer : openssl rand -base64 32
BETTER_AUTH_SECRET=""
# BETTER_AUTH_URL = URL publique où Better Auth est servi.
#   Local : http://localhost:3000
#   Prod  : https://getdrop.cloud (DOIT match le domaine résolu, sinon les magic
#           link cliqués depuis l'email échouent en INVALID_TOKEN)
# DIFFER
BETTER_AUTH_URL="http://localhost:3000"

# ─── Cron — bearer token pour /api/cron/expire ──────────────────────────────
# Générer : openssl rand -hex 32
# Documenter dans DEPLOY.md la commande curl/Schedule qui consomme cette valeur.
CRON_SECRET=""

# ─── Visitor hashing (RGPD anonyme) ─────────────────────────────────────────
# SALT_SEED = secret long & aléatoire. Une rotation quotidienne est dérivée
# par HMAC(SALT_SEED, today_UTC) → impossible de corréler un visiteur jour J/J+1.
# Générer : openssl rand -hex 32
SALT_SEED=""

# ─── Upstash Redis (rate limiting) ──────────────────────────────────────────
# Service externe HTTP — fonctionne identiquement local / Vercel / Hostinger.
# Free tier suffit pour le hackathon. Credentials REST API.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── URL publique de base ───────────────────────────────────────────────────
# Utilisée par le client (CSP, OG meta, links absolus). Doit être EXACTEMENT
# le scheme + host servis par Traefik (pas de trailing slash).
# DIFFER
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ─── Storage uploads (photo patron optionnelle) ─────────────────────────────
# Chemin filesystem où les uploads sont écrits + servis par /uploads/<path>.
#   Local : laisser vide → fallback ./public/uploads (servi par Next direct).
#   Prod Hostinger : /data/uploads, point de montage d'un VOLUME PERSISTANT
#                    déclaré dans Dokploy. Sans ça, les fichiers disparaissent
#                    à chaque redéploiement du conteneur.
# Cf. DEPLOY.md section "Volume persistant uploads".
# DIFFER
UPLOAD_DIR=""
