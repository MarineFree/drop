# Database (Postgres — Docker local / Neon / Supabase)
DATABASE_URL="postgresql://user:pass@localhost:5432/drop?schema=public"

# Anthropic
ANTHROPIC_API_KEY="sk-ant-..."

# Modèle primaire pour la génération de DropContent.
#   "sonnet" (défaut) → claude-sonnet-4-6 — moins cher, latence + faible, qualité suffisante
#                       pour du JSON contraint par Zod + system prompt clair.
#   "opus"            → claude-opus-4-7  — opt-in pour cas exigeants.
# Trade-off à valider par A/B sur ~50 générations réelles. Le fallback automatique
# va vers sonnet si primary fail.
DROP_GENERATION_MODEL="sonnet"

# fal.ai — Flux Schnell
FAL_KEY=""

# OpenAI — uniquement pour Whisper (transcription voice)
OPENAI_API_KEY=""

# Cron — bearer token pour /api/cron/expire
CRON_SECRET=""

# Visitor hashing (RGPD-anonyme)
# SALT_SEED = secret long & aléatoire. Une rotation quotidienne est dérivée
# par HMAC(SALT_SEED, today_UTC) → impossible de corréler un visiteur jour J / J+1.
SALT_SEED=""

# Upstash (rate limiting de /api/generate)
# Crée une DB Upstash Redis (free tier OK pour le hackathon) et colle les credentials REST.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Base URL publique
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
